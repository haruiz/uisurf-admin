# UISurf admin API configuration

# Public API mount path.
API_ROOT_PATH=/api

# Firebase Admin configuration for authenticated admin endpoints.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Session lifecycle and container orchestration settings.
SESSION_BASE_PORT=7000
UI_AGENT_IMAGE=uisurf-agent:latest
UI_AGENT_CONTAINER_PORT=6080
SESSION_CONTAINER_PREFIX=uisurf-agent-session
SESSION_BIND_HOST=127.0.0.1

# Public host used to build session VNC/browser URLs returned to clients.
PUBLIC_VNC_HOST=127.0.0.1
PUBLIC_VNC_SCHEME=http

# At least one provider key must be set and will be forwarded into agent containers.
GEMINI_API_KEY=
GOOGLE_API_KEY=
